# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# macOS custom-folder-icon artifact (literal filename "Icon" + carriage return),
# not a prefix match - broader patterns like `Icon*` also swallow real icon*.png/svg assets.
Icon[\r]
# dependencies
.vscode
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/dist
# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
k8s/**

/*.md
